<?xml version="1.0" encoding="utf-8"?>
<form>
	<fields name="filter">
		<field
			name="search"
			type="text"
			label="JSEARCH_FILTER"
			description="JSEARCH_FILTER"
			hint="Search bookings"
		/>
		<field name="status" type="list" label="Status" onchange="this.form.submit();">
